# trenchkit reads real credentials from ~/.config/trenchkit/.env (chmod 600)
# populated via `trenchkit init`. This file documents the shape only.

# Required — get one at https://gmgn.ai/ai
GMGN_API_KEY=your_api_key_here

# Optional — Ed25519 private key PEM, enables `trenchkit trade`.
# Without it, analysis commands (scan, wallet, smartmoney, research) still work.
# GMGN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# The following live in ~/.config/trenchkit/config.json, not env:
#   defaultChain        sol | bsc | base
#   maxTradeAmount      hard cap on native-currency spend per buy (default 1)
#   defaultPriorityFee  SOL priority fee auto-applied when TP/SL attached (default 0.00001)
#   defaultTipFee       SOL tip fee auto-applied when TP/SL attached (default 0.00001)
#   walletAddress       optional, used by `trade buy/sell/orders` if --wallet omitted
