{
  "name": "trenchkit",
  "version": "0.1.0",
  "description": "From 500 GMGN trending tokens to 3-5 high-conviction plays, in your terminal. CLI + TUI dashboard for SOL / BSC / Base, built on the GMGN OpenAPI.",
  "type": "module",
  "bin": {
    "trenchkit": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "ARCHITECTURE.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "gmgn",
    "solana",
    "bsc",
    "base",
    "crypto",
    "memecoin",
    "trading",
    "smart-money",
    "cli",
    "tui",
    "ink",
    "terminal",
    "dashboard",
    "intelligence",
    "scanner"
  ],
  "author": {
    "name": "LW Arts",
    "email": "lw.arts.designer@gmail.com",
    "url": "https://lwdesigns.art"
  },
  "license": "MIT",
  "homepage": "https://github.com/LW-ARTS/trenchkit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LW-ARTS/trenchkit.git"
  },
  "bugs": {
    "url": "https://github.com/LW-ARTS/trenchkit/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@noble/ed25519": "^3.1.0",
    "bottleneck": "^2.19.5",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "cosmiconfig": "^9.0.1",
    "dotenv": "^17.4.2",
    "ink": "^7.0.0",
    "p-retry": "^8.0.0",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
